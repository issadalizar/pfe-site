# Configuration du serveur
PORT=5000

# Configuration MongoDB
MONGODB_URI=mongodb://localhost:27017/pfe_db
# Alternative avec authentification:
# MONGODB_URI=mongodb://username:password@localhost:27017/pfe_db?authSource=admin

# JWT Secret (pour l'authentification future)
# JWT_SECRET=your-secret-key-here

# Environnement
#les variables d'environnement sont utilisées pour stocker des informations sensibles telles que les URI de connexion, les clés API, etc. Cela permet de ne pas exposer ces informations dans le code source et de les gérer de manière sécurisée.
NODE_ENV=development
